# ─── Wallet Configuration ─────────────────────────────
# Private key of the deployer (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# ─── RPC URLs ─────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Block Explorer API Keys ─────────────────────────
BASESCAN_API_KEY=your_basescan_api_key_here

# ─── Distribution Wallets ────────────────────────────
# Replace with your actual wallet addresses
COMMUNITY_WALLET=0x0000000000000000000000000000000000000000
LIQUIDITY_POOL=0x0000000000000000000000000000000000000000
DEVELOPMENT_WALLET=0x0000000000000000000000000000000000000000
MARKETING_WALLET=0x0000000000000000000000000000000000000000
TEAM_WALLET=0x0000000000000000000000000000000000000000

# ─── Optional ─────────────────────────────────────────
REPORT_GAS=false
