# ─── Telegram Bot ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── AI Providers ──────────────────────────────────────────
# Groq (free, recommended): https://console.groq.com
GROQ_API_KEY=

# OpenAI (optional, paid): https://platform.openai.com
OPENAI_API_KEY=

# ─── Blockchain (for token deployment) ────────────────────
# Wallet private key (NEVER commit this!)
PRIVATE_KEY=

# Base chain RPCs
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=

# ─── Distribution Wallet Addresses ────────────────────────
# Fill these with your wallet addresses before deployment
COMMUNITY_WALLET=
LIQUIDITY_WALLET=
DEV_WALLET=
MARKETING_WALLET=
TEAM_WALLET=

# ─── Bot Settings ─────────────────────────────────────────
DEFAULT_MODEL=llama-3.3-70b-versatile
RATE_LIMIT_PER_MIN=5
ADMIN_IDS=
